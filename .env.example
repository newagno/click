# Incrypted Account Credentials
INCRYPTED_EMAIL=your_email@example.com
INCRYPTED_PASSWORD=your_secure_password

# Telegram Notification Settings (Create a bot via @BotFather and get chat ID via @userinfobot)
TG_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
TG_CHAT_ID=987654321

# Optional Proxy settings (Format: user:pass@ip:port or ip:port)
# Residential proxies are highly recommended to bypass Cloudflare flags and prevent bans
RESIDENTIAL_PROXY=

# Silent mode for daily check-in timer checks (set to True to prevent Telegram spam every 3 hours)
SILENT_ON_COOLDOWN=True
